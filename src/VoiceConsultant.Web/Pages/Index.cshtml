@page
@model IndexModel
@{
    ViewData["Title"] = "Voice Consultant Calls";
}

<h1>Voice Consultant Calls</h1>
<p>Call transcripts and Foundry agent feedback stored in Cosmos DB.</p>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
@if (Model.StatusMessage is not null)
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}
@if (Model.Calls.Count == 0)
{
    <p>No calls have been recorded yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Call Id</th>
                <th>Consultant</th>
                <th>Received</th>
                <th>Suggestion Detected</th>
                <th>Suggestions</th>
                <th>Summary</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var call in Model.Calls)
            {
                <tr>
                    <td>@call.Conversation.CallId</td>
                    <td>@call.Conversation.ConsultantId</td>
                    <td>@call.Conversation.CreatedAt.ToLocalTime()</td>
                    <td>
                        @if (call.Insight is null)
                        {
                            <span>Pending</span>
                        }
                        else if (call.Insight.SuggestionDetected)
                        {
                            <span class="badge bg-danger">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-success">No</span>
                        }
                    </td>
                    <td>
                        @foreach (var suggestion in call.Insight?.Suggestions ?? new())
                        {
                            <div><strong>@suggestion.Topic:</strong> @string.Join(", ", suggestion.Suggestions)</div>
                        }
                    </td>
                    <td>@call.Insight?.Summary</td>
                    <td>
                        <form method="post" asp-page-handler="Retrigger">
                            <input type="hidden" name="id" value="@call.Conversation.Id" />
                            <input type="hidden" name="callId" value="@call.Conversation.CallId" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Retrigger</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
